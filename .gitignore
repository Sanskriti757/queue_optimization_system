# 🔥 Python / FastAPI .gitignore

# ------------------------------

# 🧪 Virtual Environment

# ------------------------------

venv/
.env/
.venv/
env/

# ------------------------------

# 🔐 Environment Variables

# ------------------------------

.env
.env.*
*.env

# ------------------------------

# 🐍 Python Cache / Bytecode

# ------------------------------

*pycache*/
*.py[cod]
*$py.class

# ------------------------------

# 📦 Distribution / Packaging

# ------------------------------

build/
dist/
*.egg-info/
.eggs/

# ------------------------------

# 📄 Logs

# ------------------------------

*.log
logs/

# ------------------------------

# 🧪 Testing / Coverage

# ------------------------------

.coverage
coverage.xml
htmlcov/
.pytest_cache/

# ------------------------------

# 🧠 IDE / Editor

# ------------------------------

.vscode/
.idea/
*.swp
*.swo

# ------------------------------

# 🗄️ Database Files

# ------------------------------

*.db
*.sqlite3

# ------------------------------

# 🐳 Docker (optional)

# ------------------------------

docker-compose.override.yml

# ------------------------------

# 📁 OS Files

# ------------------------------

.DS_Store
Thumbs.db

# ------------------------------

# 🚀 FastAPI specific

# ------------------------------

*.pid
uvicorn.log

# ------------------------------

# 🔑 Secrets / Keys

# ------------------------------

*.pem
*.key
*.crt

# ------------------------------

# 🧾 Migrations (optional - depends)

# ------------------------------

# migrations/

# alembic/versions/

# ------------------------------
# Node.js / React / Vite
# ------------------------------
node_modules/
frontend/node_modules/

# Frontend build artifacts
frontend/dist/
.vite/
frontend/.cache/

# Package manager and tooling caches
.npm/
.pnpm-store/
.yarn/
.eslintcache

# Tailwind/PostCSS cache (if created by tooling)
*.cache

# Frontend logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*